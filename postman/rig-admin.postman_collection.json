{
  "info": {
    "name": "B2Game Backend API",
    "description": "Express + JWT + Prisma/PostgreSQL backend collection. Run Login first; it saves {{token}} for Bearer auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api" },
    { "key": "token", "value": "" },
    { "key": "branchId", "value": "" },
    { "key": "simulatorId", "value": "" },
    { "key": "sessionId", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "bookingId", "value": "" },
    { "key": "repairId", "value": "" },
    { "key": "saleId", "value": "" },
    { "key": "shiftId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.access_token) pm.environment.set('token', json.data.access_token);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"superadmin@b2game.uz\",\n  \"password\": \"superadmin123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        }
      ]
    },
    {
      "name": "Dashboard Data",
      "item": [
        {
          "name": "Branches",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/branches", "host": ["{{baseUrl}}"], "path": ["branches"] }
          }
        },
        {
          "name": "Simulator Map",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/simulators/map?branch_id=all", "host": ["{{baseUrl}}"], "path": ["simulators", "map"], "query": [{ "key": "branch_id", "value": "all" }] }
          }
        },
        {
          "name": "Dashboard Summary",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/dashboard/summary?branch_id=all", "host": ["{{baseUrl}}"], "path": ["dashboard", "summary"], "query": [{ "key": "branch_id", "value": "all" }] }
          }
        },
        {
          "name": "Logs",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/logs?branch_id=all", "host": ["{{baseUrl}}"], "path": ["logs"], "query": [{ "key": "branch_id", "value": "all" }] }
          }
        }
      ]
    },
    {
      "name": "Sessions And Payments",
      "item": [
        {
          "name": "Start Session",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"simulator_id\": \"{{simulatorId}}\",\n  \"customer_name\": \"Postman Customer\",\n  \"phone\": \"998901112233\",\n  \"payment_mode\": \"paid\",\n  \"duration_minutes\": 30,\n  \"paid_amount\": 30000,\n  \"method\": \"card\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/sessions/start", "host": ["{{baseUrl}}"], "path": ["sessions", "start"] }
          }
        },
        {
          "name": "Add Time",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"minutes\": 15,\n  \"amount\": 15000,\n  \"method\": \"card\"\n}" },
            "url": { "raw": "{{baseUrl}}/sessions/{{sessionId}}/add-time", "host": ["{{baseUrl}}"], "path": ["sessions", "{{sessionId}}", "add-time"] }
          }
        },
        {
          "name": "Create Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branch_id\": \"{{branchId}}\",\n  \"session_id\": \"{{sessionId}}\",\n  \"method\": \"card\",\n  \"cash_amount\": 0,\n  \"card_amount\": 30000,\n  \"qr_amount\": 0,\n  \"balance_amount\": 0\n}"
            },
            "url": { "raw": "{{baseUrl}}/payments", "host": ["{{baseUrl}}"], "path": ["payments"] }
          }
        },
        {
          "name": "Stop Session",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/sessions/{{sessionId}}/stop", "host": ["{{baseUrl}}"], "path": ["sessions", "{{sessionId}}", "stop"] }
          }
        }
      ]
    },
    {
      "name": "Cashier",
      "item": [
        {
          "name": "Cashier Products",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/cashier/products?branch_id={{branchId}}", "host": ["{{baseUrl}}"], "path": ["cashier", "products"], "query": [{ "key": "branch_id", "value": "{{branchId}}" }] }
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branch_id\": \"{{branchId}}\",\n  \"name\": \"Postman Cola\",\n  \"category\": \"Drinks\",\n  \"barcode\": \"PM-COLA-001\",\n  \"price\": 9000,\n  \"cost\": 6000,\n  \"is_active\": true,\n  \"stock_quantity\": 20\n}"
            },
            "url": { "raw": "{{baseUrl}}/products", "host": ["{{baseUrl}}"], "path": ["products"] }
          }
        },
        {
          "name": "Scan Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"branch_id\": \"{{branchId}}\",\n  \"barcode\": \"PM-COLA-001\"\n}" },
            "url": { "raw": "{{baseUrl}}/cashier/scan", "host": ["{{baseUrl}}"], "path": ["cashier", "scan"] }
          }
        },
        {
          "name": "Create Sale",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"branch_id\": \"{{branchId}}\",\n  \"items\": [\n    { \"product_id\": \"{{productId}}\", \"quantity\": 1 }\n  ]\n}" },
            "url": { "raw": "{{baseUrl}}/cashier/sales", "host": ["{{baseUrl}}"], "path": ["cashier", "sales"] }
          }
        },
        {
          "name": "Pay Sale",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"method\": \"cash\",\n  \"cash_amount\": 9000,\n  \"card_amount\": 0,\n  \"qr_amount\": 0,\n  \"balance_amount\": 0\n}" },
            "url": { "raw": "{{baseUrl}}/cashier/sales/{{saleId}}/pay", "host": ["{{baseUrl}}"], "path": ["cashier", "sales", "{{saleId}}", "pay"] }
          }
        }
      ]
    },
    {
      "name": "Bookings Repairs Shifts",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"branch_id\": \"{{branchId}}\",\n  \"simulator_id\": \"{{simulatorId}}\",\n  \"booking_type\": \"customer_booking\",\n  \"customer_name\": \"Postman Customer\",\n  \"phone\": \"998901112233\",\n  \"start_time\": \"2026-06-05T18:00:00.000Z\",\n  \"end_time\": \"2026-06-05T19:00:00.000Z\",\n  \"status\": \"confirmed\",\n  \"note\": \"Postman booking\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/bookings", "host": ["{{baseUrl}}"], "path": ["bookings"] }
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/bookings/{{bookingId}}/cancel", "host": ["{{baseUrl}}"], "path": ["bookings", "{{bookingId}}", "cancel"] }
          }
        },
        {
          "name": "Create Repair Request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"simulator_id\": \"{{simulatorId}}\",\n  \"title\": \"Wheel issue\",\n  \"description\": \"Wheel calibration fails\",\n  \"error_type\": \"device_error\",\n  \"priority\": \"high\",\n  \"admin_note\": \"Created from Postman\"\n}" },
            "url": { "raw": "{{baseUrl}}/repair-requests", "host": ["{{baseUrl}}"], "path": ["repair-requests"] }
          }
        },
        {
          "name": "Approve Repair",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/repair-requests/{{repairId}}/approve", "host": ["{{baseUrl}}"], "path": ["repair-requests", "{{repairId}}", "approve"] }
          }
        },
        {
          "name": "Open Shift",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"branch_id\": \"{{branchId}}\",\n  \"starting_cash\": 200000\n}" },
            "url": { "raw": "{{baseUrl}}/shifts/open", "host": ["{{baseUrl}}"], "path": ["shifts", "open"] }
          }
        },
        {
          "name": "Close Shift",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"actual_cash\": 250000,\n  \"notes\": \"Closed from Postman\"\n}" },
            "url": { "raw": "{{baseUrl}}/shifts/{{shiftId}}/close", "host": ["{{baseUrl}}"], "path": ["shifts", "{{shiftId}}", "close"] }
          }
        }
      ]
    },
    {
      "name": "Simulator Controls",
      "item": [
        {
          "name": "Patch Simulator Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"ready_to_play\"\n}" },
            "url": { "raw": "{{baseUrl}}/simulators/{{simulatorId}}/status", "host": ["{{baseUrl}}"], "path": ["simulators", "{{simulatorId}}", "status"] }
          }
        },
        {
          "name": "Notify Simulator Rig",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"message\": \"Hello from Postman\"\n}" },
            "url": { "raw": "{{baseUrl}}/simulators/{{simulatorId}}/notify", "host": ["{{baseUrl}}"], "path": ["simulators", "{{simulatorId}}", "notify"] }
          }
        }
      ]
    }
  ]
}
