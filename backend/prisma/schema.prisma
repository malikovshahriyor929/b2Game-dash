generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String
  branchId     String?  @map("branch_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("users")
}

model Branch {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  code      String   @unique
  address   String?
  phone     String?
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("branches")
}

model Simulator {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId         String    @map("branch_id") @db.Uuid
  name             String
  code             String
  zone             String
  simulatorType    String    @map("simulator_type")
  status           String    @default("ready_to_play")
  deviceId         String?   @unique @map("device_id")
  ipAddress        String?   @map("ip_address")
  wsRigId          String?   @map("ws_rig_id")
  isOnline         Boolean   @default(false) @map("is_online")
  currentSessionId String?   @map("current_session_id") @db.Uuid
  lastSeenAt       DateTime? @map("last_seen_at")
  mapPosition      Json?     @map("map_position")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  @@unique([branchId, code])
  @@map("simulators")
}

model Tariff {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId        String?  @map("branch_id") @db.Uuid
  name            String
  simulatorZone   String   @map("simulator_zone")
  durationMinutes Int      @map("duration_minutes")
  price           Decimal
  type            String
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
  weekdayPrice    Decimal? @map("weekday_price") @db.Decimal(14, 2)
  weekendPrice    Decimal? @map("weekend_price") @db.Decimal(14, 2)
  weekdayBonus    String?  @map("weekday_bonus")
  weekendBonus    String?  @map("weekend_bonus")

  @@map("tariffs")
}

model Customer {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId      String    @map("branch_id") @db.Uuid
  name          String
  phone         String
  balance       Decimal   @default(0)
  bonus         Decimal   @default(0)
  totalSpent    Decimal   @default(0) @map("total_spent")
  sessionsCount Int       @default(0) @map("sessions_count")
  lastVisitAt   DateTime? @map("last_visit_at")
  status        String    @default("active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("customers")
}

model Session {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId         String    @map("branch_id") @db.Uuid
  simulatorId      String    @map("simulator_id") @db.Uuid
  customerId       String?   @map("customer_id") @db.Uuid
  customerName     String?   @map("customer_name")
  phone            String?
  tariffId         String?   @map("tariff_id") @db.Uuid
  status           String
  paymentMode      String    @map("payment_mode")
  startedAt        DateTime  @default(now()) @map("started_at")
  endedAt          DateTime? @map("ended_at")
  durationMinutes  Int       @map("duration_minutes")
  addedMinutes     Int       @default(0) @map("added_minutes")
  remainingSeconds Int       @default(0) @map("remaining_seconds")
  sessionAmount    Decimal   @default(0) @map("session_amount")
  addedTimeAmount  Decimal   @default(0) @map("added_time_amount")
  shopAmount       Decimal   @default(0) @map("shop_amount")
  totalAmount      Decimal   @default(0) @map("total_amount")
  paidAmount       Decimal   @default(0) @map("paid_amount")
  debtAmount       Decimal   @default(0) @map("debt_amount")
  createdBy        String    @map("created_by") @db.Uuid
  stoppedBy        String?   @map("stopped_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("sessions")
}

model Payment {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  sessionId      String?  @map("session_id") @db.Uuid
  saleId         String?  @map("sale_id") @db.Uuid
  customerId     String?  @map("customer_id") @db.Uuid
  amount         Decimal
  method         String
  cashAmount     Decimal  @default(0) @map("cash_amount")
  cardAmount     Decimal  @default(0) @map("card_amount")
  qrAmount       Decimal  @default(0) @map("qr_amount")
  balanceAmount  Decimal  @default(0) @map("balance_amount")
  status         String   @default("paid")
  paidByAdminId  String   @map("paid_by_admin_id") @db.Uuid
  paidAt         DateTime @default(now()) @map("paid_at")
  createdAt      DateTime @default(now()) @map("created_at")
  receivedAmount Decimal? @map("received_amount") @db.Decimal(14, 2)
  changeAmount   Decimal  @default(0) @map("change_amount") @db.Decimal(14, 2)

  @@map("payments")
}

model Product {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  category  String
  barcode   String   @unique
  price     Decimal
  cost      Decimal  @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  icon      String   @default("snack") @db.VarChar(40)

  @@map("products")
}

model Inventory {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId          String   @map("branch_id") @db.Uuid
  productId         String   @map("product_id") @db.Uuid
  stockQuantity     Int      @default(0) @map("stock_quantity")
  lowStockThreshold Int      @default(5) @map("low_stock_threshold")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([branchId, productId])
  @@map("inventory")
}

model InventoryMovement {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId       String   @map("branch_id") @db.Uuid
  productId      String   @map("product_id") @db.Uuid
  type           String
  quantity       Int
  beforeQuantity Int      @map("before_quantity")
  afterQuantity  Int      @map("after_quantity")
  reason         String?
  createdBy      String   @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("inventory_movements")
}

model Sale {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId      String    @map("branch_id") @db.Uuid
  sessionId     String?   @map("session_id") @db.Uuid
  customerId    String?   @map("customer_id") @db.Uuid
  soldBy        String    @map("sold_by") @db.Uuid
  subtotal      Decimal
  discount      Decimal   @default(0)
  total         Decimal
  totalCost     Decimal   @map("total_cost")
  profit        Decimal
  paymentStatus String    @default("pending") @map("payment_status")
  paymentMethod String    @default("cash") @map("payment_method")
  createdAt     DateTime  @default(now()) @map("created_at")
  paidAt        DateTime? @map("paid_at")

  @@map("sales")
}

model SaleItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId      String  @map("sale_id") @db.Uuid
  productId   String  @map("product_id") @db.Uuid
  productName String  @map("product_name")
  barcode     String
  quantity    Int
  unitPrice   Decimal @map("unit_price")
  unitCost    Decimal @map("unit_cost")
  totalPrice  Decimal @map("total_price")
  totalCost   Decimal @map("total_cost")
  profit      Decimal

  @@map("sale_items")
}

model Booking {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId        String   @map("branch_id") @db.Uuid
  simulatorId     String   @map("simulator_id") @db.Uuid
  bookingType     String   @map("booking_type")
  customerId      String?  @map("customer_id") @db.Uuid
  customerName    String?  @map("customer_name")
  phone           String?
  repairRequestId String?  @map("repair_request_id") @db.Uuid
  startTime       DateTime @map("start_time")
  endTime         DateTime @map("end_time")
  status          String   @default("pending")
  note            String?
  createdBy       String   @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("bookings")
}

model RepairRequest {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId        String    @map("branch_id") @db.Uuid
  simulatorId     String    @map("simulator_id") @db.Uuid
  requestedBy     String    @map("requested_by") @db.Uuid
  approvedBy      String?   @map("approved_by") @db.Uuid
  confirmedBy     String?   @map("confirmed_by") @db.Uuid
  title           String
  description     String
  errorType       String    @map("error_type")
  priority        String
  status          String    @default("requested")
  adminNote       String?   @map("admin_note")
  superAdminNote  String?   @map("super_admin_note")
  requestedAt     DateTime  @default(now()) @map("requested_at")
  approvedAt      DateTime? @map("approved_at")
  fixingStartedAt DateTime? @map("fixing_started_at")
  markedFixedAt   DateTime? @map("marked_fixed_at")
  confirmedAt     DateTime? @map("confirmed_at")
  revenueImpact   Decimal   @default(0) @map("revenue_impact")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("repair_requests")
}

model Shift {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId      String    @map("branch_id") @db.Uuid
  openedBy      String    @map("opened_by") @db.Uuid
  closedBy      String?   @map("closed_by") @db.Uuid
  status        String    @default("open")
  shiftType     String?   @map("shift_type")
  startingCash  Decimal   @default(0) @map("starting_cash")
  expectedCash  Decimal   @default(0) @map("expected_cash")
  actualCash    Decimal?  @map("actual_cash")
  cashSales     Decimal   @default(0) @map("cash_sales")
  cardTotal     Decimal   @default(0) @map("card_total")
  qrTotal       Decimal   @default(0) @map("qr_total")
  balanceSales  Decimal   @default(0) @map("balance_sales")
  totalRevenue  Decimal   @default(0) @map("total_revenue")
  productSales  Decimal   @default(0) @map("product_sales")
  sessionSales  Decimal   @default(0) @map("session_sales")
  cashWithdrawn Decimal   @default(0) @map("cash_withdrawn")
  cardWithdrawn Decimal   @default(0) @map("card_withdrawn")
  bankWithdrawn Decimal   @default(0) @map("bank_withdrawn")
  remainingCash Decimal   @default(0) @map("remaining_cash")
  withdrawRecipient String? @map("withdraw_recipient")
  refunds       Decimal   @default(0)
  difference    Decimal   @default(0)
  notes         String?
  openedAt      DateTime  @default(now()) @map("opened_at")
  closedAt      DateTime? @map("closed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("shifts")
}

model ShiftWithdrawal {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shiftId     String   @map("shift_id") @db.Uuid
  branchId    String   @map("branch_id") @db.Uuid
  source      String // 'cash' | 'card' | 'bank'
  amount      Decimal
  recipient   String?
  note        String?
  withdrawnBy String   @map("withdrawn_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([shiftId])
  @@index([branchId])
  @@map("shift_withdrawals")
}

model Log {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId    String?  @map("branch_id") @db.Uuid
  actorId     String?  @map("actor_id") @db.Uuid
  actorName   String?  @map("actor_name")
  actorRole   String?  @map("actor_role")
  actionType  String   @map("action_type")
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id") @db.Uuid
  simulatorId String?  @map("simulator_id") @db.Uuid
  sessionId   String?  @map("session_id") @db.Uuid
  amount      Decimal?
  details     Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("logs")
}

model Setting {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branchId  String?  @map("branch_id") @db.Uuid
  key       String
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([branchId, key])
  @@map("settings")
}

model RigConnection {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rigId         String    @unique @map("rig_id")
  simulatorId   String?   @map("simulator_id") @db.Uuid
  branchId      String?   @map("branch_id") @db.Uuid
  hostname      String
  label         String
  version       String    @default("unknown")
  latestVersion String?   @map("latest_version")
  locked        Boolean   @default(false)
  lockMessage   String?   @map("lock_message")
  online        Boolean   @default(false)
  updateStatus  String?   @map("update_status")
  firstSeenAt   DateTime? @map("first_seen_at")
  lastSeenAt    DateTime? @map("last_seen_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("rig_connections")
}
